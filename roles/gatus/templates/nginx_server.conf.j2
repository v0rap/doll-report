map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    listen [::]:80;

    server_name {{ dashboard_name }}.doll.report;

    location / {
        resolver 127.0.0.11;
        set $gatus_instance gatus-{{ dashboard_name }}:8080;
        proxy_pass http://$gatus_instance;
        proxy_set_header Host $host;
        proxy_http_version 1.1;
        proxy_redirect off;

        # For WebSocket
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
    include conf.d/502error.def;
}
